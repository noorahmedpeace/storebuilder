generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StoreStatus {
  TRIAL
  LIVE
  SUSPENDED
  REVIEW
}

enum OrderStatus {
  DRAFT
  PENDING
  PAID
  PACKING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  COD
  EASYPAISA
  JAZZCASH
  RAAST
  STRIPE
}

model Store {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  status      StoreStatus  @default(TRIAL)
  currency    String       @default("PKR")
  timezone    String       @default("Asia/Karachi")
  businessType   String?
  tagline        String?
  logoText       String?
  brandColor     String    @default("#143c3a")
  accentColor    String    @default("#f3b74f")
  themeKey       String    @default("modern-retail")
  whatsapp       String?
  announcement   String?
  heroHeading    String?
  heroSubheading String?
  aboutText      String?
  logoUrl        String?
  fontKey        String?
  gaId           String?
  clarityId      String?
  layout         Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  domains     Domain[]
  members     StoreMember[]
  customers   Customer[]
  categories  Category[]
  products    Product[]
  warehouses  Warehouse[]
  orders      Order[]
  coupons     Coupon[]
  auditLogs   AuditLog[]
  subscription Subscription?
  newsletterSubscribers NewsletterSubscriber[]
  carts       Cart[]
  leads       Lead[]
}

model Lead {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  phone     String
  email     String?
  message   String?
  kind      String   @default("contact")
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  storeId   String
  email     String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
  @@index([storeId])
}

model Domain {
  id        String   @id @default(cuid())
  storeId   String
  host      String   @unique
  verified  Boolean  @default(false)
  primary   Boolean  @default(false)
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model User {
  id          String        @id @default(cuid())
  email       String        @unique
  name        String
  passwordHash String?
  twoFactorEnabled Boolean  @default(false)
  isSuperAdmin Boolean      @default(false)
  createdAt   DateTime      @default(now())
  memberships StoreMember[]
}

model Role {
  id          String        @id @default(cuid())
  name        String        @unique
  permissions Permission[]
  members     StoreMember[]
}

model Permission {
  id     String @id @default(cuid())
  action String @unique
  roles  Role[]
}

model StoreMember {
  id        String   @id @default(cuid())
  storeId   String
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([storeId, userId])
  @@index([storeId])
  @@index([userId])
}

model Customer {
  id        String   @id @default(cuid())
  storeId   String
  email     String?
  phone     String?
  name      String
  tags      String[]
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([storeId])
  @@index([storeId, phone])
  @@index([storeId, email])
}

model Category {
  id        String    @id @default(cuid())
  storeId   String
  name      String
  slug      String
  parentId  String?
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parent    Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]

  @@unique([storeId, slug])
  @@index([storeId])
}

model Product {
  id          String           @id @default(cuid())
  storeId     String
  categoryId  String?
  title       String
  slug        String
  description String
  status      String           @default("draft")
  seoTitle    String?
  seoDescription String?
  features    String?
  specs       String?
  faq         String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  store       Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category    Category?        @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  images      ProductImage[]
  reviews     Review[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([storeId, status])
}

model ProductVariant {
  id        String         @id @default(cuid())
  productId String
  sku       String
  title     String
  price     Decimal        @db.Decimal(12, 2)
  compareAtPrice Decimal?  @db.Decimal(12, 2)
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory InventoryItem[]
  orderItems OrderItem[]
  cartItems CartItem[]

  @@unique([productId, sku])
}

model Cart {
  id        String     @id @default(cuid())
  storeId   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([storeId])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int            @default(1)
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Warehouse {
  id        String          @id @default(cuid())
  storeId   String
  name      String
  city      String
  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  inventory InventoryItem[]

  @@index([storeId])
}

model InventoryItem {
  id          String         @id @default(cuid())
  variantId   String
  warehouseId String
  quantity    Int            @default(0)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([variantId, warehouseId])
}

model Order {
  id          String      @id @default(cuid())
  storeId     String
  customerId  String?
  status      OrderStatus @default(PENDING)
  subtotal    Decimal     @db.Decimal(12, 2)
  shippingFee Decimal     @default(0) @db.Decimal(12, 2)
  total       Decimal     @db.Decimal(12, 2)
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  shippingAddress String?
  shippingCity    String?
  paymentMethod   String?
  createdAt   DateTime    @default(now())
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer    Customer?   @relation(fields: [customerId], references: [id])
  items       OrderItem[]
  payment     Payment?
  shipment    Shipment?

  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, createdAt])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  price     Decimal        @db.Decimal(12, 2)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

model Payment {
  id          String          @id @default(cuid())
  orderId     String          @unique
  provider    PaymentProvider
  status      String
  amount      Decimal         @db.Decimal(12, 2)
  reference   String?
  rawPayload   Json?
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Shipment {
  id          String @id @default(cuid())
  orderId     String @unique
  courier     String
  trackingNo  String?
  status      String
  rawPayload  Json?
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Coupon {
  id        String   @id @default(cuid())
  storeId   String
  code      String
  type      String
  value     Decimal  @db.Decimal(12, 2)
  startsAt  DateTime?
  endsAt    DateTime?
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, code])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  rating    Int
  title     String?
  body      String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String   @id @default(cuid())
  storeId   String   @unique
  plan      String
  status    String
  renewsAt  DateTime?
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  storeId   String?
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([createdAt])
}
